# hapi-hub configuration. Copy to `.env` and edit.
# Secrets are read at runtime — never commit your real .env.

# ---- Core ----

# Base shared secret for CLI + web login. Clients append ":<namespace>" for
# multi-user isolation. Leave UNSET to auto-generate on first run (persisted in
# the hapi-data volume; shown once in `docker compose logs hub`).
# CLI_API_TOKEN=

# Public HTTPS URL the hub is reachable at (provided by your reverse proxy).
# Used for the Telegram Mini App and to derive default CORS origins.
HAPI_PUBLIC_URL=https://hapi.example.com

# Comma-separated allowed CORS origins, or "*". When unset, defaults derive from
# HAPI_PUBLIC_URL. Set this if the web UI is hosted on a different origin.
# CORS_ORIGINS=https://hapi.example.com

# HTTP bind / port. The Dockerfile already binds 0.0.0.0:3006; only override if
# you know you need to.
# HAPI_LISTEN_HOST=0.0.0.0
# HAPI_LISTEN_PORT=3006

# ---- Optional: Telegram bot ----
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_NOTIFICATION=true

# ---- Optional: Voice assistant (ElevenLabs) ----
# ELEVENLABS_API_KEY=
# ELEVENLABS_AGENT_ID=

# ---- Optional: Web Push (VAPID) ----
# VAPID_SUBJECT=mailto:you@example.com

# ---- Optional: Server酱 push ----
# SERVERCHAN_SENDKEY=
